ARG RUST_BASE_IMAGE=rust:1.93-bookworm
FROM ${RUST_BASE_IMAGE} AS dev-base

RUN apt-get update 2>/dev/null || true; \
    apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        ncat \
        nodejs \
        npm \
        openssh-client \
        pkg-config \
        libssl-dev \
        python3 \
        python3-pip \
        python3-venv \
        unzip \
    2>/dev/null || true; \
    rm -rf /var/lib/apt/lists/*

# Install DuckDB CLI
ARG DBTX_GITHUB_RELEASES_URL=https://github.com
RUN set -eux; \
    curl -fsSL "${DBTX_GITHUB_RELEASES_URL}/duckdb/duckdb/releases/download/v1.3.0/duckdb_cli-linux-amd64.zip" -o /tmp/duckdb.zip; \
    unzip /tmp/duckdb.zip -d /usr/local/bin; \
    chmod +x /usr/local/bin/duckdb; \
    rm /tmp/duckdb.zip

WORKDIR /workspace

RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

ENV CARGO_TARGET_DIR=/workspace/target
ENV PATH=/usr/local/cargo/bin:${PATH}
ENV SHELL=/bin/bash

FROM dev-base AS worker-dev

ARG DBTX_FUSION_DOWNLOAD_URL=https://public.cdn.getdbt.com/fs/install/install.sh

RUN set -eux; \
    if [ -z "${DBTX_FUSION_DOWNLOAD_URL}" ]; then \
        echo "DBTX_FUSION_DOWNLOAD_URL must point to a dbt Fusion install script" >&2; \
        exit 1; \
    fi; \
    curl -fsSL "${DBTX_FUSION_DOWNLOAD_URL}" | sh -s -- --update; \
    if [ -x /root/.local/bin/dbt ]; then \
        ln -sf /root/.local/bin/dbt /usr/local/bin/dbt; \
        ln -sf /root/.local/bin/dbt /usr/local/bin/dbt-fusion; \
    elif [ -x /root/.local/bin/dbt-fusion ]; then \
        ln -sf /root/.local/bin/dbt-fusion /usr/local/bin/dbt-fusion; \
        ln -sf /root/.local/bin/dbt-fusion /usr/local/bin/dbt; \
    else \
        echo "dbt Fusion install script completed without producing /root/.local/bin/dbt or /root/.local/bin/dbt-fusion" >&2; \
        exit 1; \
    fi

ENV DBTX_DBT_PATH=/usr/local/bin/dbt
